# ── RPC Provider ──────────────────────────────────────────
# Get a free key at https://www.alchemy.com
ALCHEMY_API_KEY=your_alchemy_key_here

# ── Deployer Wallet ───────────────────────────────────────
# Private key of the wallet that pays gas for deployment
# NEVER commit the real .env file — .env is in .gitignore
DEPLOYER_PRIVATE_KEY=your_private_key_here

# ── Etherscan Verification ────────────────────────────────
# Get a free key at https://etherscan.io/myapikey
ETHERSCAN_API_KEY=your_etherscan_api_key_here

# ── Contract Roles (Sepolia testnet addresses) ────────────
# These are the wallets that will hold each role on testnet
GOVERNMENT_ADDRESS=0x_drc_government_wallet
CCR_OPERATOR_ADDRESS=0x_ccr_operator_wallet
